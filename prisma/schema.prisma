// Cahier des charges section 5 (Modele de donnees) -> Prisma schema.
// One extension beyond the spec: Category.keywords, used as an offline
// fallback for category suggestion when the LLM can't be reached (section
// 7.1 requires the app to stay fully usable offline).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  banque
  cash
}

enum CategoryType {
  depense
  revenu
}

enum TransactionType {
  depense
  revenu
  transfert
}

enum BudgetPeriod {
  mensuel
}

enum InsightType {
  resume_mensuel
  anomalie
  prevision
}

// ponctuel = prevision one-off; the others make a charge fixe.
enum Recurrence {
  ponctuel
  hebdomadaire
  mensuel
  annuel
}

// donne = money left my pocket toward the friend (loan or repaying him),
// recu = money came in from the friend. Friend's balance = donne - recu.
enum PretDirection {
  donne
  recu
}

enum ContributionSens {
  verse
  retire
}

model Account {
  id             String   @id @default(uuid())
  nom            String
  type           AccountType
  soldeInitial   Decimal  @default(0) @db.Decimal(14, 2)
  devise         String   @default("MRU")
  couleur        String // swatch used throughout the UI; not in the cahier's table but needed for the design
  actif          Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  transactions        Transaction[] @relation("SourceAccount")
  transfersIn         Transaction[] @relation("DestAccount")
  echeances           Echeance[]
  pretMouvements      PretMouvement[]

  @@map("accounts")
}

model Category {
  id       String       @id @default(uuid())
  nom      String
  type     CategoryType
  icone    String?
  couleur  String
  keywords String[]     @default([])
  parentId String?
  parent   Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[]   @relation("CategoryHierarchy")

  transactions Transaction[]
  budget       Budget?
  echeances    Echeance[]

  @@map("categories")
}

model Transaction {
  id                 String            @id @default(uuid())
  compteId           String
  compte             Account           @relation("SourceAccount", fields: [compteId], references: [id], onDelete: Cascade)
  compteDestinationId String?
  compteDestination  Account?          @relation("DestAccount", fields: [compteDestinationId], references: [id], onDelete: SetNull)
  type               TransactionType
  montant            Decimal           @db.Decimal(14, 2)
  categorieId        String?
  categorie          Category?         @relation(fields: [categorieId], references: [id], onDelete: SetNull)
  libelle            String?
  date               DateTime          @default(now())
  synced             Boolean           @default(true)
  creeHorsLigne      Boolean           @default(false)
  clientId           String?           @unique // dedupe key set by the offline client so a queued write can't be double-applied
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  pretMouvement PretMouvement?

  @@index([compteId])
  @@index([date])
  @@map("transactions")
}

// Charge fixe (recurrence != ponctuel) or prevision ponctuelle. Paying one
// creates a real Transaction and advances prochaineDate (or deactivates a
// one-off).
model Echeance {
  id            String       @id @default(uuid())
  nom           String
  type          CategoryType
  montant       Decimal      @db.Decimal(14, 2)
  recurrence    Recurrence   @default(mensuel)
  prochaineDate DateTime
  compteId      String?
  compte        Account?     @relation(fields: [compteId], references: [id], onDelete: SetNull)
  categorieId   String?
  categorie     Category?    @relation(fields: [categorieId], references: [id], onDelete: SetNull)
  actif         Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([prochaineDate])
  @@map("echeances")
}

model Ami {
  id        String   @id @default(uuid())
  nom       String
  couleur   String
  createdAt DateTime @default(now())

  mouvements PretMouvement[]

  @@map("amis")
}

model PretMouvement {
  id            String        @id @default(uuid())
  amiId         String
  ami           Ami           @relation(fields: [amiId], references: [id], onDelete: Cascade)
  direction     PretDirection
  montant       Decimal       @db.Decimal(14, 2)
  note          String?
  date          DateTime      @default(now())
  compteId      String?
  compte        Account?      @relation(fields: [compteId], references: [id], onDelete: SetNull)
  // Linked Transaction when a compte was chosen, so the account balance moves too.
  transactionId String?       @unique
  transaction   Transaction?  @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())

  @@index([amiId])
  @@map("pret_mouvements")
}

model Budget {
  id             String       @id @default(uuid())
  categorieId    String       @unique
  categorie      Category     @relation(fields: [categorieId], references: [id], onDelete: Cascade)
  montantLimite  Decimal      @db.Decimal(14, 2)
  seuilAlerte    Int          @default(80) // percent
  periode        BudgetPeriod @default(mensuel)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("budgets")
}

model Insight {
  id               String      @id @default(uuid())
  type             InsightType
  contenu          String
  periodeConcernee DateTime
  dateGeneration   DateTime    @default(now())

  @@map("insights")
}

// Savings goal for a big purchase/project. Contributions are virtual
// allocations (the money stays on the accounts): epargne = verse - retire,
// and the dashboard shows global balance minus what is reserved here.
model Projet {
  id           String    @id @default(uuid())
  nom          String
  couleur      String
  montantCible Decimal   @db.Decimal(14, 2)
  dateCible    DateTime?
  actif        Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  contributions ProjetContribution[]

  @@map("projets")
}

model ProjetContribution {
  id        String           @id @default(uuid())
  projetId  String
  projet    Projet           @relation(fields: [projetId], references: [id], onDelete: Cascade)
  sens      ContributionSens @default(verse)
  montant   Decimal          @db.Decimal(14, 2)
  note      String?
  date      DateTime         @default(now())
  createdAt DateTime         @default(now())

  @@index([projetId])
  @@map("projet_contributions")
}

// Single-row table: mono-user app, local PIN auth per section 4.1/7.2.
model AppSettings {
  id              Int      @id @default(1)
  pinHash         String
  pinSalt         String
  accentColor     String   @default("oklch(0.72 0.14 150)")
  aiSuggestions   Boolean  @default(true)
  autoLockMinutes Int      @default(2)
  updatedAt       DateTime @updatedAt

  @@map("app_settings")
}
